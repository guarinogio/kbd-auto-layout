#compdef kbd-auto-layoutctl

_kbd_auto_layoutctl() {
  local -a commands
  commands=(
    'list:List detected keyboard devices'
    'layouts:List available X11 keyboard layouts'
    'variants:List variants for a layout'
    'assign:Assign layout to a device'
    'remove:Remove a device rule'
    'set-default:Set fallback default layout'
    'set-poll-interval:Set polling interval in seconds'
    'reload:Reload daemon config'
    'edit:Open user config in editor'
    'init-config:Create default user config'
    'doctor:Run environment checks'
    'status:Show config and current layout'
    'completion-zsh:Print zsh completion script'
  )

  local -a match_modes
  match_modes=('exact:Exact name match' 'contains:Substring match')

  local curcontext="$curcontext" state line

  _arguments -C \
    '1:command:->command' \
    '*::arg:->args'

  case "$state" in
    command)
      _describe -t commands 'kbd-auto-layoutctl commands' commands
      ;;
    args)
      case "$words[2]" in
        list)
          _arguments \
            '--connected[Show only connected devices]' \
            '--json[Output as JSON]'
          ;;
        status)
          _arguments '--json[Output as JSON]'
          ;;
        variants)
          _arguments '1:layout:_message "layout"'
          ;;
        assign)
          _arguments \
            '1:device name:_message "device name"' \
            '2:layout:_message "layout"' \
            '3:variant:_message "variant"' \
            '--match[Match mode]:match mode:(exact contains)'
          ;;
        remove)
          _arguments \
            '1:device name:_message "device name"' \
            '--match[Match mode]:match mode:(exact contains)'
          ;;
        set-default)
          _arguments \
            '1:layout:_message "layout"' \
            '2:variant:_message "variant"'
          ;;
        set-poll-interval)
          _arguments '1:seconds:_message "seconds"'
          ;;
        init-config)
          _arguments '--force[Overwrite existing config]'
          ;;
      esac
      ;;
  esac
}

_kbd_auto_layoutctl "$@"
